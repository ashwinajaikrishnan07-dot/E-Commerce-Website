// ============================================================
// VIRTUAL TAILOR STUDIO — Database Schema
// Normalized PostgreSQL schema for the garment customization platform
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  avatarUrl     String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  projects      DesignProject[]
  orders        Order[]
  favorites     Favorite[]
  adminLogs     AdminLog[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

// ============================================================
// BODY PARTS & CATEGORIES
// ============================================================

model BodyPart {
  id          String   @id @default(uuid())
  name        String   @unique // chest, collar, neck, sleeves, etc.
  label       String   // Human-readable label
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  components  ClothingComponent[]
  embroideries EmbroideryPattern[]

  @@map("body_parts")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  label       String
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  components  ClothingComponent[]
  textures    FabricTexture[]
  embroideries EmbroideryPattern[]

  @@map("categories")
}

// ============================================================
// GARMENT COMPONENTS
// ============================================================

model ClothingComponent {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  bodyPartId    String
  bodyPart      BodyPart @relation(fields: [bodyPartId], references: [id])
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  modelUrl      String   // GLB model URL
  thumbnailUrl  String
  price         Decimal  @default(0) @db.Decimal(10, 2)
  tags          String[] @default([])
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  defaultMaterial  Material? @relation("DefaultMaterial", fields: [defaultMaterialId], references: [id])
  defaultMaterialId String?
  compatibleTextures ComponentTexture[]
  compatibleColors   ComponentColor[]
  designComponents   DesignComponent[]

  @@index([bodyPartId])
  @@index([categoryId])
  @@map("clothing_components")
}

// ============================================================
// MATERIALS & TEXTURES
// ============================================================

model Material {
  id                  String   @id @default(uuid())
  name                String
  baseColor           String   @default("#FFFFFF")
  metalness           Float    @default(0)
  roughness           Float    @default(0.5)
  normalMapUrl        String?
  aoMapUrl            String?
  displacementMapUrl  String?
  emissiveColor       String?
  emissiveIntensity   Float    @default(0)
  opacity             Float    @default(1)
  transparent         Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  components          ClothingComponent[] @relation("DefaultMaterial")

  @@map("materials")
}

model FabricTexture {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  thumbnailUrl    String
  diffuseMapUrl   String
  normalMapUrl    String?
  roughnessMapUrl String?
  repeatX         Float    @default(1)
  repeatY         Float    @default(1)
  rotation        Float    @default(0)
  price           Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  compatibleComponents ComponentTexture[]
  designComponents     DesignComponent[]

  @@index([categoryId])
  @@map("fabric_textures")
}

model ColorSwatch {
  id          String   @id @default(uuid())
  name        String
  hex         String
  category    String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  compatibleComponents ComponentColor[]
  designComponents     DesignComponent[]

  @@map("color_swatches")
}

model EmbroideryPattern {
  id              String     @id @default(uuid())
  name            String
  slug            String     @unique
  categoryId      String
  category        Category   @relation(fields: [categoryId], references: [id])
  thumbnailUrl    String
  patternUrl      String
  defaultColor    String     @default("#D4AF37")
  bodyPartId      String
  bodyPart        BodyPart   @relation(fields: [bodyPartId], references: [id])
  price           Decimal    @default(0) @db.Decimal(10, 2)
  isActive        Boolean    @default(true)
  sortOrder       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  designComponents DesignComponent[]

  @@index([categoryId])
  @@index([bodyPartId])
  @@map("embroidery_patterns")
}

// ============================================================
// JUNCTION TABLES
// ============================================================

model ComponentTexture {
  componentId String
  component   ClothingComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  textureId   String
  texture     FabricTexture     @relation(fields: [textureId], references: [id], onDelete: Cascade)

  @@id([componentId, textureId])
  @@map("component_textures")
}

model ComponentColor {
  componentId String
  component   ClothingComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  colorId     String
  color       ColorSwatch       @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@id([componentId, colorId])
  @@map("component_colors")
}

// ============================================================
// DESIGN PROJECTS
// ============================================================

model DesignProject {
  id              String          @id @default(uuid())
  name            String
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  garmentCategory String
  thumbnailUrl    String?
  isPublic        Boolean         @default(false)
  isFavorite      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  components      DesignComponent[]
  orders          OrderItem[]
  shares          ShareLink[]
  favorites       Favorite[]

  @@index([userId])
  @@map("design_projects")
}

model DesignComponent {
  id              String   @id @default(uuid())
  projectId       String
  project         DesignProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bodyRegion      String
  componentId     String?
  component       ClothingComponent? @relation(fields: [componentId], references: [id])
  textureId       String?
  texture         FabricTexture?   @relation(fields: [textureId], references: [id])
  colorId         String?
  color           ColorSwatch?     @relation(fields: [colorId], references: [id])
  embroideryId    String?
  embroidery      EmbroideryPattern? @relation(fields: [embroideryId], references: [id])
  embroideryColor String?
  materialOverrides Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, bodyRegion])
  @@index([projectId])
  @@map("design_components")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING)
  totalAmount   Decimal     @db.Decimal(10, 2)
  currency      String      @default("INR")
  notes         String?
  shippingAddress Json?
  measurements  Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  items         OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id          String        @id @default(uuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  projectId   String
  project     DesignProject @relation(fields: [projectId], references: [id])
  quantity    Int           @default(1)
  price       Decimal       @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([orderId])
  @@map("order_items")
}

// ============================================================
// SHARING & FAVORITES
// ============================================================

model ShareLink {
  id            String   @id @default(uuid())
  projectId     String
  project       DesignProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shareToken    String   @unique @default(uuid())
  isPublic      Boolean  @default(true)
  allowEditing  Boolean  @default(false)
  expiresAt     DateTime?
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([shareToken])
  @@map("share_links")
}

model Favorite {
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   DesignProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@id([userId, projectId])
  @@map("favorites")
}

// ============================================================
// MEDIA & ASSETS
// ============================================================

model Media {
  id          String    @id @default(uuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  url         String
  thumbnailUrl String?
  type        MediaType
  metadata    Json?
  uploadedBy  String?
  createdAt   DateTime  @default(now())

  @@index([type])
  @@map("media")
}

enum MediaType {
  MODEL
  TEXTURE
  EMBROIDERY
  THUMBNAIL
  SCREENSHOT
  OTHER
}

// ============================================================
// ADMIN LOGS
// ============================================================

model AdminLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("admin_logs")
}
